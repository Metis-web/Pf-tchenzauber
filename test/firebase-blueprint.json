{
  "entities": {
    "animal": {
      "title": "Animal",
      "description": "An animal looking for a home",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "age": { "type": "string" },
        "status": { "type": "string" },
        "imageUrl": { "type": "string", "description": "URL to the image" },
        "weight": { "type": "string" },
        "castrated": { "type": "boolean" },
        "dewormed": { "type": "boolean" },
        "chipped": { "type": "boolean" },
        "vaccinated": { "type": "boolean" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["name", "description", "status"]
    },
    "inquiry": {
      "title": "Inquiry",
      "description": "Adoption inquiry for an animal",
      "type": "object",
      "properties": {
        "animalId": { "type": "string" },
        "animalName": { "type": "string" },
        "userId": { "type": "string", "description": "ID of the user making the inquiry" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "motivation": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["animalId", "animalName", "userId", "name", "email", "phone", "motivation", "createdAt"]
    },
    "admin": {
      "title": "Admin",
      "description": "Admin user marker",
      "type": "object",
      "properties": {},
      "required": []
    }
  },
  "firestore": {
    "/animals/{animalId}": {
      "schema": { "$ref": "#/entities/animal" },
      "description": "Stores animal profiles"
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/inquiry" },
      "description": "Stores user adoption inquiries"
    },
    "/admins/{userId}": {
      "schema": { "$ref": "#/entities/admin" },
      "description": "Stores admin user IDs as document keys"
    }
  }
}
